# ----------------------------------------------------------------------------
# HouseSync environment variables
# ----------------------------------------------------------------------------
# 1. Copy this file to ".env.local"
# 2. Create a free project at https://supabase.com
# 3. In the Supabase dashboard: Project Settings -> API
#      - "Project URL"            -> NEXT_PUBLIC_SUPABASE_URL
#      - "anon" / "public" key    -> NEXT_PUBLIC_SUPABASE_ANON_KEY
# 4. Restart `npm run dev` after changing these.
# ----------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The public base URL of the app. Used to build invite links and OAuth
# redirects. For local dev this is fine; change it to your real domain in
# production (e.g. https://housesync.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: which social sign-in buttons to show (comma-separated).
# Defaults to "google,azure,apple". Set this to only the providers you've
# actually enabled in the Supabase dashboard, e.g. "google,azure".
# NEXT_PUBLIC_OAUTH_PROVIDERS=google,azure,apple

# ----------------------------------------------------------------------------
# Email reminders (SERVER-SIDE ONLY — never prefix these with NEXT_PUBLIC).
# Add these in Vercel -> Settings -> Environment Variables for production.
# ----------------------------------------------------------------------------
# Brevo API key (Brevo -> SMTP & API -> API Keys). Used to send reminder emails.
BREVO_API_KEY=
# Supabase service-role key (Project Settings -> API -> service_role, secret).
# Lets the daily cron read across all houses to build reminders. KEEP SECRET.
SUPABASE_SERVICE_ROLE_KEY=
# A random string you invent. Set the SAME value in Vercel so that only Vercel
# Cron can trigger the /api/cron/reminders endpoint.
CRON_SECRET=
# Optional sender overrides (defaults shown):
# REMINDER_FROM_EMAIL=hello@housesync.co.uk
# REMINDER_REPLY_TO=hellohousesync@outlook.com

# SMS phone verification + (future) SMS reminders use the SAME BREVO_API_KEY
# above, but require SMS credits on your Brevo account. Optional sender name
# (alphanumeric, max 11 chars; some countries require registration):
# SMS_SENDER=HouseSync
