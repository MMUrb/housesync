<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Dark-mode overrides. A night-qualified style fully replaces the default,
         so this re-declares the base AppTheme.NoActionBar items plus the dark
         bar colours (light icons on the app's dark navy chrome). -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:statusBarColor">#0A0A16</item>
        <item name="android:navigationBarColor">#0A0A16</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
